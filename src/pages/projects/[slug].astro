---
import Layout from '../../layouts/Layout.astro';
import { buildRepoTags, fetchPublicRepos, formatDate } from '../../lib/github';

export async function getStaticPaths() {
	const repos = await fetchPublicRepos();
	const paths = repos.map((repo) => ({
		params: { slug: repo.slug },
		props: {
			repo,
			repos,
		},
	}));

	return paths;
}

const { repo, repos } = Astro.props;
const tags = buildRepoTags(repo);
---

<Layout
	title={`${repo.name} | gvillarroel Public Projects`}
	description={repo.description}
>
	<div class="page-shell">
		<header class="site-header">
			<div>
				<a class="site-title" href="../index.html">gvillarroel / static docs</a>
				<div class="site-tagline">{repo.fullName}</div>
			</div>
			<div class="cta-row">
				<a class="button-link" href="../index.html">Back to index</a>
				<a class="button-link" href={repo.repoUrl}>Open on GitHub</a>
			</div>
		</header>

		<div class="grid-shell">
			<aside class="sidebar">
				<div class="kicker">Repository Nav</div>
				<strong>Projects</strong>
				<ul class="repo-list">
					{
						repos.map((entry) => (
							<li>
								<a href={`${entry.slug}.html`} data-active={entry.slug === repo.slug ? 'true' : 'false'}>
									<span class="repo-name">{entry.name}</span>
									<span class="repo-meta">{entry.description}</span>
								</a>
							</li>
						))
					}
				</ul>
			</aside>

			<main class="panel">
				<div class="kicker">Repository Snapshot</div>
				<h1 style="margin: 0 0 0.8rem;">{repo.name}</h1>
				<p class="lead">{repo.description}</p>
				<div class="tag-list">
					{tags.map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
				<div class="stats">
					<div class="stat">
						<strong>Repository</strong>
						<span>{repo.fullName}</span>
					</div>
					<div class="stat">
						<strong>Default branch</strong>
						<span>{repo.defaultBranch}</span>
					</div>
					<div class="stat">
						<strong>Language</strong>
						<span>{repo.language ?? 'Not detected'}</span>
					</div>
					<div class="stat">
						<strong>Updated</strong>
						<span>{formatDate(repo.updatedAt)}</span>
					</div>
					<div class="stat">
						<strong>Created</strong>
						<span>{formatDate(repo.createdAt)}</span>
					</div>
					<div class="stat">
						<strong>Stars</strong>
						<span>{repo.stars}</span>
					</div>
					<div class="stat">
						<strong>Open issues</strong>
						<span>{repo.openIssues}</span>
					</div>
				</div>

				<section class="docs" style="margin-top: 2rem;">
					<div class="card-grid">
						<article class="card">
							<strong>Repository URL</strong>
							<p><a href={repo.repoUrl}>{repo.repoUrl}</a></p>
						</article>
						<article class="card">
							<strong>Default branch</strong>
							<p><code>{repo.defaultBranch}</code></p>
						</article>
						<article class="card">
							<strong>Homepage</strong>
							<p>{repo.homepage ? <a href={repo.homepage}>{repo.homepage}</a> : 'No homepage set'}</p>
						</article>
						<article class="card">
							<strong>Repository type</strong>
							<p>
								{repo.archived ? 'Archived' : 'Active'}
								{repo.fork ? ' fork' : ' source repository'}
							</p>
						</article>
					</div>

					<div class="empty-state" style="margin-top: 1.4rem;">
						This page is generated entirely from GitHub repository metadata during the Astro build.
						No external README markup is copied into the static output, which keeps all project pages
						visually consistent.
					</div>
				</section>
			</main>
		</div>
	</div>
</Layout>
