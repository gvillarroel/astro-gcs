---
import Layout from '../layouts/Layout.astro';
import { featuredRepos, repos } from '../data/repos';

const now = new Intl.DateTimeFormat('en-US', {
	dateStyle: 'long',
	timeStyle: 'short',
	timeZone: 'America/New_York',
}).format(new Date());
---

<Layout
	title="gvillarroel Public Projects"
	description="Static documentation hub for public gvillarroel repositories, generated with Astro and deployed to Google Cloud Storage."
>
	<div class="page-shell">
		<header class="site-header">
			<div>
				<div class="site-title">gvillarroel / static docs</div>
				<div class="site-tagline">Public repository documentation baked into static HTML for bucket hosting.</div>
			</div>
			<a class="button-link" href="https://github.com/gvillarroel">GitHub profile</a>
		</header>

		<div class="grid-shell">
			<aside class="sidebar">
				<div class="kicker">Repository Nav</div>
				<strong>Public projects</strong>
				<ul class="repo-list">
					{
						repos.map((repo) => (
							<li>
								<a href={`projects/${repo.slug}.html`}>
									<span class="repo-name">{repo.name}</span>
									<span class="repo-meta">{repo.summary}</span>
								</a>
							</li>
						))
					}
				</ul>
			</aside>

			<main class="panel">
				<div class="kicker">Static Documentation Hub</div>
				<h1 class="hero-title">Public project docs with bucket-safe navigation.</h1>
				<p class="lead">
					This site indexes public repositories under <code>gvillarroel</code>, adds a usable
					navigation layer, and turns reviewed README content into static pages that can be uploaded
					directly to Google Cloud Storage.
				</p>
				<div class="stats">
					<div class="stat">
						<strong>Repositories</strong>
						<span>{repos.length} public entries indexed</span>
					</div>
					<div class="stat">
						<strong>Hosting</strong>
						<span>Astro static build on GCS</span>
					</div>
					<div class="stat">
						<strong>Navigation</strong>
						<span>Relative links for object URL browsing</span>
					</div>
					<div class="stat">
						<strong>Built</strong>
						<span>{now}</span>
					</div>
				</div>

				<div class="cta-row">
					<a class="button-link" href="https://github.com/gvillarroel/astro-gcs">Site source</a>
					<a class="button-link" href="projects/knowledge.html">Open a project page</a>
				</div>

				<section>
					<div class="card-grid">
						{
							featuredRepos.map((repo) => (
								<article class="card">
									<strong>{repo.name}</strong>
									<p>{repo.summary}</p>
									<div class="tag-list">
										{repo.tags.map((tag) => (
											<span class="tag">{tag}</span>
										))}
									</div>
									<div class="cta-row">
										<a class="button-link" href={`projects/${repo.slug}.html`}>Read docs</a>
										<a class="button-link" href={repo.repoUrl}>GitHub</a>
									</div>
								</article>
							))
						}
					</div>
				</section>
			</main>
		</div>
	</div>
</Layout>
