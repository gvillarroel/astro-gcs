---
import Layout from '../layouts/Layout.astro';
import { buildRepoTags, fetchPublicRepos, formatDate } from '../lib/github';

const repos = await fetchPublicRepos();
const featuredRepos = repos.slice(0, 10);

const now = new Intl.DateTimeFormat('en-US', {
	dateStyle: 'long',
	timeStyle: 'short',
	timeZone: 'America/New_York',
}).format(new Date());
---

<Layout
	title="gvillarroel Public Projects"
	description="Static documentation hub for public gvillarroel repositories, generated with Astro and deployed to Google Cloud Storage."
>
	<div class="page-shell">
		<header class="site-header">
			<div>
				<div class="site-title">gvillarroel / static docs</div>
				<div class="site-tagline">Public repository documentation and integration examples baked into static HTML for bucket hosting.</div>
			</div>
			<div class="cta-row" style="margin-top: 0;">
				<a class="button-link" href="/integrations/index.html">Integration examples</a>
				<a class="button-link" href="https://github.com/gvillarroel">GitHub profile</a>
			</div>
		</header>

		<div class="grid-shell">
			<aside class="sidebar">
				<div class="kicker">Repository Nav</div>
				<strong>Public projects</strong>
				<ul class="repo-list">
					{
						repos.map((repo) => (
							<li>
								<a href={`projects/${repo.slug}.html`}>
									<span class="repo-name">{repo.name}</span>
									<span class="repo-meta">{repo.description}</span>
								</a>
							</li>
						))
					}
				</ul>
			</aside>

			<main class="panel">
				<div class="kicker">Astro Build-Time GitHub Index</div>
				<h1 class="hero-title">Uniform project pages generated from GitHub metadata.</h1>
				<p class="lead">
					This site iterates the public repositories under <code>gvillarroel</code> during the Astro
					build, generates one static page per repository, and renders everything with the same local
					template instead of embedding external README markup.
				</p>
				<div class="stats">
					<div class="stat">
						<strong>Repositories</strong>
						<span>{repos.length} public entries indexed</span>
					</div>
					<div class="stat">
						<strong>Hosting</strong>
						<span>Astro static build on GCS</span>
					</div>
					<div class="stat">
						<strong>Source model</strong>
						<span>GitHub API metadata at build time</span>
					</div>
					<div class="stat">
						<strong>Examples</strong>
						<span>Local, remote, and knowledge-backed Markdown</span>
					</div>
					<div class="stat">
						<strong>Built</strong>
						<span>{now}</span>
					</div>
				</div>

				<div class="cta-row">
					<a class="button-link" href="https://github.com/gvillarroel/astro-gcs">Site source</a>
					<a class="button-link" href="projects/knowledge.html">Open a project page</a>
					<a class="button-link" href="/integrations/index.html">Browse integration examples</a>
				</div>

				<section>
					<div class="card-grid">
						{
							featuredRepos.map((repo) => (
								<article class="card">
									<strong>{repo.name}</strong>
									<p>{repo.description}</p>
									<p class="repo-meta">Updated {formatDate(repo.updatedAt)}</p>
									<div class="tag-list">
										{buildRepoTags(repo).map((tag) => (
											<span class="tag">{tag}</span>
										))}
									</div>
									<div class="cta-row">
										<a class="button-link" href={`projects/${repo.slug}.html`}>Read docs</a>
										<a class="button-link" href={repo.repoUrl}>GitHub</a>
									</div>
								</article>
							))
						}
					</div>
				</section>
			</main>
		</div>
	</div>
</Layout>
