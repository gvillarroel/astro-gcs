---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found" description="Static documentation site 404 page.">
	<div class="page-shell">
		<main
			class="panel"
			style="max-width: 760px; margin: 12vh auto 0; text-align: center;"
		>
			<div class="kicker">404 / Missing Route</div>
			<h1 class="hero-title" style="max-width: none;">Path not found.</h1>
			<p class="lead" style="margin: 0 auto;">
				This static documentation build does not contain a page at this path. Use the index to jump
				back into the public repository docs.
			</p>
			<div class="cta-row" style="justify-content: center;">
				<a class="button-link" href="./index.html">Return to index</a>
			</div>
		</main>
	</div>
</Layout>
