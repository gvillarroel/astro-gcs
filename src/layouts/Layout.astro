---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--bg: #f7f1e7;
		--paper: rgba(255, 252, 247, 0.84);
		--panel: rgba(255, 255, 255, 0.7);
		--ink: #1a2733;
		--muted: #5a6b78;
		--line: rgba(26, 39, 51, 0.12);
		--accent: #b5532f;
		--accent-2: #2a6b62;
		--shadow: 0 24px 60px rgba(26, 39, 51, 0.12);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		font-family: Georgia, 'Times New Roman', serif;
		color: var(--ink);
		background:
			radial-gradient(circle at top left, rgba(181, 83, 47, 0.18), transparent 28%),
			radial-gradient(circle at top right, rgba(42, 107, 98, 0.2), transparent 22%),
			linear-gradient(180deg, #fcf8f2 0%, var(--bg) 100%);
	}

	a {
		color: inherit;
	}

	code,
	pre {
		font-family: 'Cascadia Code', Consolas, monospace;
	}

	.page-shell {
		width: min(1280px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.25rem 0 2rem;
	}

	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0 1.5rem;
	}

	.site-header a {
		text-decoration: none;
	}

	.site-title {
		font-size: 0.8rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent-2);
	}

	.site-tagline {
		color: var(--muted);
		font-size: 0.98rem;
	}

	.grid-shell {
		display: grid;
		grid-template-columns: 300px minmax(0, 1fr);
		gap: 1.25rem;
		align-items: start;
	}

	.sidebar,
	.panel {
		border: 1px solid var(--line);
		border-radius: 28px;
		background: var(--paper);
		backdrop-filter: blur(12px);
		box-shadow: var(--shadow);
	}

	.sidebar {
		position: sticky;
		top: 1rem;
		padding: 1.1rem;
	}

	.panel {
		padding: clamp(1.2rem, 3vw, 2.25rem);
	}

	.repo-list {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		display: grid;
		gap: 0.55rem;
	}

	.repo-list a {
		display: block;
		padding: 0.8rem 0.9rem;
		border-radius: 18px;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.6);
		border: 1px solid transparent;
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			background 0.18s ease;
	}

	.repo-list a:hover,
	.repo-list a[data-active='true'] {
		transform: translateY(-1px);
		border-color: var(--line);
		background: rgba(255, 255, 255, 0.95);
	}

	.repo-name {
		display: block;
		font-size: 1rem;
		margin-bottom: 0.25rem;
	}

	.repo-meta {
		display: block;
		color: var(--muted);
		font-size: 0.87rem;
		line-height: 1.45;
	}

	.kicker {
		display: inline-block;
		font-size: 0.76rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent-2);
		margin-bottom: 1rem;
	}

	.hero-title {
		font-size: clamp(2.6rem, 7vw, 5.2rem);
		line-height: 0.95;
		margin: 0 0 1rem;
		max-width: 10ch;
	}

	.lead {
		font-size: clamp(1rem, 2vw, 1.18rem);
		line-height: 1.75;
		color: var(--muted);
		max-width: 64ch;
	}

	.stats,
	.card-grid {
		display: grid;
		gap: 1rem;
	}

	.stats {
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		margin-top: 1.8rem;
	}

	.card-grid {
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		margin-top: 2rem;
	}

	.stat,
	.card {
		background: var(--panel);
		border: 1px solid var(--line);
		border-radius: 22px;
		padding: 1rem;
	}

	.stat strong,
	.card strong {
		display: block;
		margin-bottom: 0.45rem;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.9rem;
	}

	.tag {
		font-size: 0.76rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.35rem 0.55rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.65);
		color: var(--muted);
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

	.button-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.8rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.9);
	}

	.docs {
		line-height: 1.75;
		font-size: 1.02rem;
	}

	.docs h1,
	.docs h2,
	.docs h3 {
		line-height: 1.15;
		margin-top: 2rem;
	}

	.docs img {
		max-width: 100%;
		height: auto;
		border-radius: 18px;
		border: 1px solid var(--line);
	}

	.docs pre {
		overflow-x: auto;
		padding: 1rem;
		border-radius: 18px;
		background: #f4eadc;
		border: 1px solid var(--line);
	}

	.docs code {
		background: rgba(181, 83, 47, 0.08);
		padding: 0.15rem 0.35rem;
		border-radius: 0.35rem;
	}

	.docs pre code {
		background: transparent;
		padding: 0;
	}

	.empty-state {
		padding: 1rem 1.1rem;
		border-radius: 18px;
		border: 1px dashed var(--line);
		background: rgba(255, 255, 255, 0.55);
		color: var(--muted);
	}

	@media (max-width: 960px) {
		.grid-shell {
			grid-template-columns: 1fr;
		}

		.sidebar {
			position: static;
		}

		.hero-title {
			max-width: none;
		}
	}
</style>
