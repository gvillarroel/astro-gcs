---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="background-stage" aria-hidden="true">
			<div class="background-slide slide-1"></div>
			<div class="background-slide slide-2"></div>
			<div class="background-slide slide-3"></div>
			<div class="background-dim"></div>
			<div class="background-noise"></div>
		</div>
		<div class="site-layer">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--paper: rgba(7, 12, 16, 0.6);
		--panel: rgba(10, 16, 22, 0.78);
		--panel-2: rgba(15, 23, 30, 0.64);
		--ink: #e9f3f6;
		--muted: #98aab3;
		--line: rgba(159, 190, 201, 0.18);
		--accent: #79f7c7;
		--accent-2: #74a7ff;
		--shadow:
			0 28px 80px rgba(0, 0, 0, 0.52),
			inset 0 1px 0 rgba(255, 255, 255, 0.06);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		font-family:
			'Cascadia Code', 'JetBrains Mono', 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
		color: var(--ink);
		background: #05090c;
	}

	.site-layer {
		position: relative;
		z-index: 1;
	}

	.background-stage,
	.background-stage::before,
	.background-stage::after {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.background-stage {
		z-index: 0;
		overflow: hidden;
		background: #030507;
	}

	.background-slide {
		position: absolute;
		inset: -4%;
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		filter: saturate(0.92) brightness(0.52);
		transform: scale(1.08);
		opacity: 0;
		animation: background-cycle 30s ease-in-out infinite;
	}

	.slide-1 {
		background-image: url('/backgrounds/nature-1.jpg');
		animation-delay: 0s;
	}

	.slide-2 {
		background-image: url('/backgrounds/nature-2.jpg');
		animation-delay: 10s;
	}

	.slide-3 {
		background-image: url('/backgrounds/nature-3.jpg');
		animation-delay: 20s;
	}

	.background-dim {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, rgba(6, 10, 13, 0.68) 0%, rgba(6, 10, 13, 0.84) 32%, rgba(6, 10, 13, 0.94) 100%),
			radial-gradient(circle at top, rgba(92, 126, 115, 0.14), transparent 34%),
			radial-gradient(circle at 82% 12%, rgba(116, 167, 255, 0.12), transparent 26%),
			radial-gradient(circle at 30% 80%, rgba(121, 247, 199, 0.08), transparent 30%);
	}

	.background-noise {
		position: absolute;
		inset: 0;
		opacity: 0.16;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px);
		background-size: 100% 4px, 4px 100%;
		mix-blend-mode: soft-light;
	}

	a {
		color: inherit;
	}

	code,
	pre {
		font-family: 'Cascadia Code', Consolas, monospace;
	}

	.page-shell {
		width: min(1280px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.25rem 0 2rem;
	}

	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0 1.5rem;
	}

	.site-header a {
		text-decoration: none;
	}

	.site-title {
		font-size: 0.8rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.site-tagline {
		color: var(--muted);
		font-size: 0.98rem;
	}

	.grid-shell {
		display: grid;
		grid-template-columns: 300px minmax(0, 1fr);
		gap: 1.25rem;
		align-items: start;
	}

	.sidebar,
	.panel {
		border: 1px solid var(--line);
		border-radius: 28px;
		background: var(--paper);
		backdrop-filter: blur(18px) saturate(110%);
		box-shadow: var(--shadow);
	}

	.sidebar {
		position: sticky;
		top: 1rem;
		padding: 1.1rem;
	}

	.panel {
		padding: clamp(1.2rem, 3vw, 2.25rem);
		background:
			linear-gradient(180deg, rgba(13, 21, 28, 0.8) 0%, rgba(8, 13, 18, 0.72) 100%),
			var(--paper);
	}

	.repo-list {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		display: grid;
		gap: 0.55rem;
	}

	.repo-list a {
		display: block;
		padding: 0.8rem 0.9rem;
		border-radius: 18px;
		text-decoration: none;
		background: rgba(10, 17, 22, 0.48);
		border: 1px solid rgba(159, 190, 201, 0.08);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			background 0.18s ease,
			box-shadow 0.18s ease;
	}

	.repo-list a:hover,
	.repo-list a[data-active='true'] {
		transform: translateY(-1px);
		border-color: rgba(121, 247, 199, 0.25);
		background: rgba(13, 24, 30, 0.82);
		box-shadow: 0 0 0 1px rgba(121, 247, 199, 0.08);
	}

	.repo-name {
		display: block;
		font-size: 1rem;
		margin-bottom: 0.25rem;
	}

	.repo-meta {
		display: block;
		color: var(--muted);
		font-size: 0.87rem;
		line-height: 1.45;
	}

	.kicker {
		display: inline-block;
		font-size: 0.76rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.hero-title {
		font-size: clamp(2.6rem, 7vw, 5.2rem);
		line-height: 1;
		margin: 0 0 1rem;
		max-width: 10ch;
		text-wrap: balance;
	}

	.lead {
		font-size: clamp(1rem, 2vw, 1.18rem);
		line-height: 1.85;
		color: var(--muted);
		max-width: 64ch;
	}

	.stats,
	.card-grid {
		display: grid;
		gap: 1rem;
	}

	.stats {
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		margin-top: 1.8rem;
	}

	.card-grid {
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		margin-top: 2rem;
	}

	.stat,
	.card {
		background: var(--panel);
		border: 1px solid var(--line);
		border-radius: 22px;
		padding: 1rem;
		backdrop-filter: blur(12px);
	}

	.stat strong,
	.card strong {
		display: block;
		margin-bottom: 0.45rem;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 0.9rem;
	}

	.tag {
		font-size: 0.76rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.35rem 0.55rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(11, 18, 24, 0.82);
		color: #b6f8df;
	}

	.cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

	.button-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.8rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		border: 1px solid var(--line);
		background: rgba(9, 15, 20, 0.8);
		color: #eaf8fb;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	.button-link:hover {
		border-color: rgba(121, 247, 199, 0.35);
		background: rgba(14, 25, 32, 0.9);
	}

	.docs {
		line-height: 1.8;
		font-size: 1.02rem;
	}

	.docs h1,
	.docs h2,
	.docs h3 {
		line-height: 1.15;
		margin-top: 2rem;
		color: #f5fbfd;
	}

	.docs img {
		max-width: 100%;
		height: auto;
		border-radius: 18px;
		border: 1px solid var(--line);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
	}

	.docs pre {
		overflow-x: auto;
		padding: 1rem;
		border-radius: 18px;
		background: rgba(3, 7, 10, 0.92);
		border: 1px solid var(--line);
		box-shadow: inset 0 0 0 1px rgba(121, 247, 199, 0.05);
	}

	.docs code {
		background: rgba(121, 247, 199, 0.08);
		padding: 0.15rem 0.35rem;
		border-radius: 0.35rem;
		color: #c5ffe9;
	}

	.docs pre code {
		background: transparent;
		padding: 0;
		color: #d4e6ec;
	}

	.empty-state {
		padding: 1rem 1.1rem;
		border-radius: 18px;
		border: 1px dashed var(--line);
		background: rgba(10, 16, 20, 0.55);
		color: var(--muted);
	}

	@keyframes background-cycle {
		0%,
		8% {
			opacity: 0;
			transform: scale(1.1);
		}

		16%,
		30% {
			opacity: 1;
			transform: scale(1.04);
		}

		38%,
		100% {
			opacity: 0;
			transform: scale(1.02);
		}
	}

	@media (max-width: 960px) {
		.grid-shell {
			grid-template-columns: 1fr;
		}

		.sidebar {
			position: static;
		}

		.hero-title {
			max-width: none;
		}
	}
</style>
